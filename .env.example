# Supabase — https://supabase.com/dashboard → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Server-only — NEVER expose to browser or commit real values
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Admin login PIN (required in production)
ADMIN_PIN=your_6_digit_pin

# Production site URL for QR codes (e.g. https://ravali-traders.vercel.app)
# Vercel sets VERCEL_URL automatically; set this if using a custom domain
NEXT_PUBLIC_APP_URL=
