# Supabase — https://supabase.com/dashboard → Project → Settings → API
# Vercel: paste keys with NO extra spaces or line breaks at the end
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Server-only — NEVER expose to browser or commit real values
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Admin login PIN (required in production)
ADMIN_PIN=123456

# Production site URL for QR codes (e.g. https://ravali-chi.vercel.app)
# Vercel sets VERCEL_URL automatically; set this if using a custom domain
NEXT_PUBLIC_APP_URL=

# Google Cloud Translation (English → Telugu, same as Google Translate)
# https://console.cloud.google.com/apis/library/translate.googleapis.com → Enable → Credentials → API key
GOOGLE_TRANSLATE_API_KEY=

# After adding env vars on Vercel: redeploy, then check /api/setup-status → ready: true
